# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project-id", "private-key"}' # Your Firebase service account JSON

# Database Configuration
# Supabase: found in supabase.com → project → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Optional: force database client (postgres | mysql). If omitted, backend auto-selects based on env values.
DATABASE_CLIENT=postgres
# Local MySQL overrides (used when DATABASE_CLIENT=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306

# Server Configuration
PORT=5050
FRONTEND_URL=https://your-production-url.com
API_URL=http://localhost:5050
FRONTEND_URL_DEV=http://localhost:5173
NODE_ENV=development

# Email / receipts
RESEND_API_KEY=
RESEND_FROM_EMAIL="C&W Market Foundation <info@cwmarketfoundation.org>"
RECEIPT_CC_EMAIL=info@cwmarketfoundation.org

# Docker Configuration
db_name=
root_password=
dev_user=
dev_password=

# Stripe
STRIPE_API_KEY=sk_test_...
SYNC_API_KEY=generate-with-openssl-rand-hex-32